#: qml/BoxBreathingPage.qml:10
#, kde-format
msgctxt "@title"
msgid "Box Breathing"
msgstr "Štvorcové dýchanie"

#: qml/BoxBreathingPage.qml:11
#, kde-format
msgid ""
"Box Breathing is used by the Navy SEALs to quickly and effectively reduce "
"stress.                    <br>                    <ul>                    "
"<li>Breathe in through your nose (4s).</li>                    <li>Hold (4s)."
"</li>                    <li>Breathe out through your nose (4s).</"
"li>                    <li>Hold (4s).</li>                    </"
"ul>                    <br>                    Repeat for at least 5-10 "
"minutes."
msgstr ""
"Štvorcové dýchanie používajú Navy SEALs na rýchle a účinné zníženie "
"stresu.                    <br>                    <ul>                    "
"<li>Nadýchnite sa nosom (4 s).</li>                    <li>Zadržte dych (4 "
"s).</li>                    <li>Vydýchnite nosom (4 s).</"
"li>                    <li>Zadržte dych (4 s).</li>                    </"
"ul>                    <br>                    Opakujte aspoň 5 – 10 minút."

#: qml/BoxBreathingSleepPage.qml:10
#, kde-format
msgctxt "@title"
msgid "Box Breathing (sleep)"
msgstr "Štvorcové dýchanie (spánok)"

#: qml/BoxBreathingSleepPage.qml:11
#, kde-format
msgid ""
"A Box Breathing variant with a longer breathe-out phase helps to relax "
"before going to sleep.                    <br>                    "
"<ul>                    <li>Breathe in through your nose (4s).</"
"li>                    <li>Hold (4s).</li>                    <li>Breathe "
"out through your nose (6s).</li>                    <li>Hold (2s).</"
"li>                    </ul>                    <br>                    "
"Repeat at least 6 times."
msgstr ""
"Variant štvorcového dýchania s dlhšou fázou výdychu pomáha uvoľniť sa pred "
"spaním.                    <br>                    <ul>                    "
"<li>Nadýchnite sa nosom (4 s).</li>                    <li>Zadržte dych (4 "
"s).</li>                    <li>Vydýchnite nosom (6 s).</"
"li>                    <li>Zadržte dych (2 s).</li>                    </"
"ul>                    <br>                    Opakujte aspoň 6-krát."

