#: qml/478BreathingPage.qml:10
#, kde-format
msgctxt "@title"
msgid "4-7-8 Breathing"
msgstr "Dýchanie 4-7-8"

#: qml/478BreathingPage.qml:11
#, kde-format
msgid ""
"4-7-8 Breathing puts the body into a deep relaxation state, e.g. to better "
"fall asleep on a flight.                    <br>                    "
"<ul>                    <li>Breathe in through your nose (4s).</"
"li>                    <li>Hold (7s).</li>                    <li>Breathe "
"out through your mouth making a whooshing sound (8s).</"
"li>                    </ul>                    <br>                    "
"Repeat at least 4 times."
msgstr ""
"Dýchanie 4-7-8 uvádza telo do stavu hlbokého uvoľnenia, napr. na lepšie "
"zaspanie počas letu.                    <br>                    "
"<ul>                    <li>Nadýchnite sa nosom (4 s).</"
"li>                    <li>Zadržte dych (7 s).</li>                    "
"<li>Vydýchnite ústami so šumivým zvukom (8 s).</li>                    </"
"ul>                    <br>                    Opakujte aspoň 4-krát."

